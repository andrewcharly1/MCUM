# MCUM — environment template. Copy to `.env` and fill in real values locally.
# `.env` is gitignored; NEVER commit real secrets. This example is safe to commit.

# ─────────────────────────────────────────
# POSTGRESQL CONNECTION (local)
# ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=change-me

# Full connection URL (used by connection.py). Keep the password in sync.
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/postgres
# Optional dedicated database for tests that require real PostgreSQL writes.
MCUM_TEST_DATABASE_URL=postgresql://postgres:change-me@localhost:5432/mcum_test

# ─────────────────────────────────────────
# MCUM CONFIG
# ─────────────────────────────────────────
MCUM_SCHEMA_BRAIN=core_brain
MCUM_SCHEMA_REGISTRY=project_registry

# Embedding backend (same all-MiniLM-L6-v2 vectors, interchangeable):
#   onnx                  -> ONNX Runtime via fastembed. ~2-3s cold, ~220MB RAM. RECOMMENDED.
#   sentence-transformers -> PyTorch. ~15-50s cold, ~440MB RAM. Same quality.
#   hash                  -> deterministic, no semantics, 0 RAM (fallback / tests).
# Switch with: py .agent/skills/MCUM/mcum_embedding.py use <backend>
MCUM_EMBEDDING_BACKEND=onnx

# Stable ONNX model cache (avoids fastembed's volatile Temp dir).
MCUM_EMBEDDING_CACHE_DIR=~/.cache/fastembed

# Offline model load: blocks the Hugging Face Hub network round-trip that caused
# >60s cold loads / mcum_search_memory timeouts. Set MCUM_EMBEDDING_ALLOW_DOWNLOAD=1
# for the one-time download on a machine without the cached model.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HUB_DISABLE_TELEMETRY=1
HF_HUB_DISABLE_SYMLINKS_WARNING=1
TOKENIZERS_PARALLELISM=false
# MCUM_EMBEDDING_ALLOW_DOWNLOAD=1

# ─────────────────────────────────────────
# FEDERATED GRAPH (code graph + projection)
# ─────────────────────────────────────────
# Skip the heavy code projection when a project's code graph exceeds this many
# nodes (typically the workspace root indexed over many sibling folders) so the
# federated sync never times out / goes stale. 0 disables the guard.
MCUM_GRAPH_MAX_CODE_PROJECTION_NODES=15000
# Per-statement timeout for the federated projection (ms). Default 90s.
# MCUM_GRAPH_STATEMENT_TIMEOUT_MS=90000

# Base path for the project registry (absolute path to your workspace).
MCUM_BASE_PATH=C:/path/to/the workspace

# Orchestrator skill identity.
MCUM_ORCHESTRATOR_SKILL=mcum-orchestrator
MCUM_ORCHESTRATOR_VERSION=1.1.0
