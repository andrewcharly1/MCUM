# Copy this file to .env and fill values locally.
# Never commit real secrets, passwords, tokens, or production URLs.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=change-me

DATABASE_URL=postgresql://postgres:change-me@localhost:5432/postgres

MCUM_SCHEMA_BRAIN=core_brain
MCUM_SCHEMA_REGISTRY=project_registry
MCUM_BASE_PATH=C:/path/to/CERTIFICACION LABORAL
MCUM_ORCHESTRATOR_SKILL=mcum-orchestrator
MCUM_ORCHESTRATOR_VERSION=1.0.0
